PACKAGE = OverlayUnidraw

LIB = OverlayUnidraw

DYLDLIBS = -L$(XLIBDIR) $(LDLIBX11) $(LDLIBXEXT) $(LDLIBIV) $(LDLIBUNIDRAW) $(LIBUNIIDRAW)  $(LIBCOMTERP) $(LIBATTRIBUTE) $(LIBCOMUTIL) $(LIBTOPOFACE) $(CLIPPOLY_CCLDLIBS) $(LIBACEDISPATCH) $(LIBCOMGLYPH) $(LIBATTRGLYPH) $(LIBCOMUTIL) $(LIBIVGLYPH) ${ACE_CCLDLIBS}

OTHER_CCDEFINES = $(CLIPPOLY_CCDEFINES) $(ACE_CCDEFINES)
OTHER_CCINCLUDES = $(CLIPPOLY_CCINCLUDES) $(ACE_CCINCLUDES)

    DEPLIBUNIDRAW = $(IVTOOLSSRC)/Unidraw/$(CPU)/libUnidraw.so.$(VERSION)
         DEPLIBIV =
       DEPLIBXEXT =
        DEPLIBX11 =
          DEPLIBM =

       LIBDIRPATH =
     LDLIBUNIDRAW = -L$(IVTOOLSSRC)/Unidraw/$(CPU) -lUnidraw
          LDLIBIV = -L$(IVTOOLSSRC)/IV/$(ARCH) -lIV
      XLIBDIRPATH = -L$(XLIBDIR)
        LDLIBXEXT = -lXext
         LDLIBX11 = -lX11
           LDLIBM = -lm
    ABSLIBDIRPATH = -L$(ABSLIBDIR)

 BACKWARD_CCDEFINES = -Div2_6_compatible
BACKWARD_CCINCLUDES = -I$(INCSRC)/IV-2_6

AOUT = lib$(LIB).so.$(VERSION)
SHARED_CCFLAGS = -fPIC

all:: lib$(LIB).so.$(VERSION)

lib$(LIB).so.$(VERSION):
	@echo "building $@"
	$(RM) $@
	gcc -shared  -o $@ $(OBJS) -lXext -lX11 -lstdc++ -lm
	$(RM) lib$(LIB).so
	$(LN) $@ lib$(LIB).so

clean::
	$(RM) lib$(LIB).so.$(VERSION)

install:: lib$(LIB).so.$(VERSION)
	-@if [ -d $(LIBDIR) ]; then exit 0; \
		else (set -x; $(MKDIRHIER) $(LIBDIR)); fi
	$(INSTALL) -c $(INSTLIBFLAGS) lib$(LIB).so.$(VERSION) $(LIBDIR)
	-@$(RM) $(LIBDIR)/lib$(LIB).so
	-@(cd $(LIBDIR);$(LN) lib$(LIB).so.$(VERSION) \
	lib$(LIB).so)

uninstall::
	$(RM) $(LIBDIR)/lib$(LIB).so.$(VERSION)
	$(RM) $(LIBDIR)/lib$(LIB).so

depend::
	$(DEPEND) $(DEPEND_CCFLAGS) $(SRCS) >Makefile.depend

