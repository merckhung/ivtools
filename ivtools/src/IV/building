    $(DISPATCH)/dispatcher.$(CCSUFFIX)\
    $(DISPATCH)/iohandler.$(CCSUFFIX)	$(OS)$(SLASH)*.$(CCSUFFIX)

LIB	   = IV

KIT_CCFLAGS = -Dmotif_kit -Dsgi_motif_kit -Dopenlook_kit -Dbw_kit -Ddefault_kit=SMFKit
LIBPATHS   = -DABSLIBALLDIR='"$(ABSLIBALLDIR)"' -DRELLIBALLDIR='"$(RELLIBALLDIR)"' 	     -DX_LIBDIR='"$(XLIBDIR)"'

DEPEND_CCFLAGS = -w -DMAKEDEPEND $(CCDEFINES) $(CCINCLUDES) 		      -I$(TOOL_INCLUDE_DIR) -UHAVE_ACE $(KIT_CCFLAGS) $(GL_CCFLAGS)

AOUT = lib$(LIB).so.$(VERSION)
SHARED_CCFLAGS = -fPIC

all:: lib$(LIB).so.$(VERSION)

lib$(LIB).so.$(VERSION):
	@echo "building $@"
	$(RM) $@
	gcc -shared  -o $@ $(OBJS) -lXext -lX11 -lstdc++ -lm
	$(RM) lib$(LIB).so
	$(LN) $@ lib$(LIB).so

clean::
	$(RM) lib$(LIB).so.$(VERSION)

install:: lib$(LIB).so.$(VERSION)
	-@if [ -d $(LIBDIR) ]; then exit 0; \
		else (set -x; $(MKDIRHIER) $(LIBDIR)); fi
	$(INSTALL) -c $(INSTLIBFLAGS) lib$(LIB).so.$(VERSION) $(LIBDIR)
	-@$(RM) $(LIBDIR)/lib$(LIB).so
	-@(cd $(LIBDIR);$(LN) lib$(LIB).so.$(VERSION) \
	lib$(LIB).so)

uninstall::
	$(RM) $(LIBDIR)/lib$(LIB).so.$(VERSION)
	$(RM) $(LIBDIR)/lib$(LIB).so

