#
# source files for building the Unidraw library
#

PACKAGE = Unidraw

LIB = Unidraw

         DEPLIBIV =
        DEPLIBX11 =
          DEPLIBM =

       LIBDIRPATH =
          LDLIBIV = -L$(IVTOOLSSRC)/IV/$(ARCH) -lIV
      XLIBDIRPATH = -L$(XLIBDIR)
        LDLIBXEXT = -lXext
         LDLIBX11 = -lX11
           LDLIBM = -lm
    ABSLIBDIRPATH = -L$(ABSLIBDIR)
DYLDLIBS = -L$(XLIBDIR) $(LDLIBX11) $(LDLIBXEXT) $(LDLIBIV)

AOUT = lib$(LIB).so.$(VERSION)
SHARED_CCFLAGS = -fPIC

all:: lib$(LIB).so.$(VERSION)

lib$(LIB).so.$(VERSION):
	@echo "building $@"
	$(RM) $@
	gcc -shared  -o $@ $(OBJS) -lXext -lX11 -lstdc++ -lm
	$(RM) lib$(LIB).so
	$(LN) $@ lib$(LIB).so

clean::
	$(RM) lib$(LIB).so.$(VERSION)

install:: lib$(LIB).so.$(VERSION)
	-@if [ -d $(LIBDIR) ]; then exit 0; \
		else (set -x; $(MKDIRHIER) $(LIBDIR)); fi
	$(INSTALL) -c $(INSTLIBFLAGS) lib$(LIB).so.$(VERSION) $(LIBDIR)
	-@$(RM) $(LIBDIR)/lib$(LIB).so
	-@(cd $(LIBDIR);$(LN) lib$(LIB).so.$(VERSION) \
	lib$(LIB).so)

uninstall::
	$(RM) $(LIBDIR)/lib$(LIB).so.$(VERSION)
	$(RM) $(LIBDIR)/lib$(LIB).so

